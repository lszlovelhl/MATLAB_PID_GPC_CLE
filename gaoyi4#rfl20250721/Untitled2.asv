%% 画1#拱顶温度与空燃比
[~,length]=size(data);
begin1=700;
%length=2500;
figure;
subplot(2,1,1);
plot(data(5,begin1:length));
hold on
plot(data(78,begin1:length)-20,'r');
for i=begin1:length
    if    data(12,i)<1
        data(12,i)=1000;
    end
portial1(i-(begin1-1))=data(13,i)/(data(12,i)+0.0001);
end
subplot(2,1,2);
plot(portial1(1:length-begin1));
hold on
plot(a_his_airgaspotial(1,begin1:length),'r');

