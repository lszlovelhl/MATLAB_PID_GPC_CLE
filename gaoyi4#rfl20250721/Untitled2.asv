%% 3#
%% 画3#拱顶温度与空燃比
[~,length]=size(data);
length=2500;
for i=2:length
    if    data(50,i)<1
        data(50,i)=1000;
    end
portial3(i-1)=data(51,i)/(data(50,i)+0.0001);
set3(i-1)=1320;
end
figure;
subplot(2,1,1);
plot(data(43,2:length));
hold on
%plot(data(80-20,2:length),'r');
plot(set3(1:length-1),'r');

subplot(2,1,2);
plot(portial3(1:length-1));
hold on
plot(a_his_airgaspotial(3,2:length),'r');
