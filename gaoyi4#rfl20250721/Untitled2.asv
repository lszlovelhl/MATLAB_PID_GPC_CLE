    if    data(31,i)<1
        data(31,i)=1000;
    end
portial2(i-1)=data(32,i)/(data(31,i)+0.0001);
end
subplot(2,1,2);
plot(portial2);
hold on
plot(a_his_airgaspotial(2,2:length),'r');
